            "url_options": {
              "data": "{\"query\": \"\\n                SELECT \\n                    CAST(date AS VARCHAR) as Data,\\n                    description as Descri\\u00e7\\u00e3o,\\n                    category as Categoria,\\n                    CASE \\n                        WHEN amount > 0 THEN 'Gasto'\\n                        ELSE 'Pagamento'\\n                    END as Tipo,\\n                    ROUND(ABS(amount), 2) as \\\"Valor (R$)\\\"\\n                FROM nubank_transactions\\n                WHERE account_type = 'credit_card'\\n                AND date >= '${__from:date:YYYY-MM-DD}' \\n                AND date <= '${__to:date:YYYY-MM-DD}'\\n                ORDER BY date DESC, ABS(amount) DESC\\n            \"}",
              "method": "POST"
            }
