            "url": "http://localhost:8089/query",
            "url_options": {
              "data": "{\"query\": \"SELECT \\n                    strftime(date, '%Y-%m') as M\\u00eas,\\n                    ROUND(SUM(CASE WHEN description ILIKE '%openai%' OR description ILIKE '%chatgpt%' OR description ILIKE '%claude%' THEN ABS(amount) ELSE 0 END), 2) as \\\"\\ud83e\\udd16 IA\\\",\\n                    ROUND(SUM(CASE WHEN description ILIKE '%netflix%' OR description ILIKE '%disney%' OR description ILIKE '%hbo%' OR description ILIKE '%helphbomax%' OR description ILIKE '%youtube%' OR description ILIKE '%spotify%' THEN ABS(amount) ELSE 0 END), 2) as \\\"\\ud83c\\udfac Streaming\\\",\\n                    ROUND(SUM(CASE WHEN description ILIKE '%apple%' OR description ILIKE '%crossover%' THEN ABS(amount) ELSE 0 END), 2) as \\\"\\ud83d\\udcf1 Apps/Software\\\",\\n                    ROUND(SUM(CASE WHEN category IN ('Music streaming','Video streaming','Digital services') AND description NOT ILIKE '%openai%' AND description NOT ILIKE '%chatgpt%' AND description NOT ILIKE '%claude%' AND description NOT ILIKE '%netflix%' AND description NOT ILIKE '%disney%' AND description NOT ILIKE '%hbo%' AND description NOT ILIKE '%helphbomax%' AND description NOT ILIKE '%youtube%' AND description NOT ILIKE '%spotify%' AND description NOT ILIKE '%apple%' AND description NOT ILIKE '%crossover%' THEN ABS(amount) ELSE 0 END), 2) as \\\"\\ud83d\\udce6 Outros Digital\\\"\\n                FROM nubank_transactions \\n                WHERE category IN ('Music streaming', 'Video streaming', 'Digital services')\\n                AND date >= '${__from:date:YYYY-MM-DD}' \\n                AND date <= '${__to:date:YYYY-MM-DD}'\\n                GROUP BY strftime(date, '%Y-%m')\\n                ORDER BY M\\u00eas\"}",
              "method": "POST"
            }
          }
        ],
