            "url_options": {
              "data": "{\"query\": \"SELECT \\n                    mes as M\\u00eas, \\n                    ROUND(gastos, 2) as Gastos, \\n                    ROUND(receitas, 2) as Receitas, \\n                    ROUND(receitas - gastos, 2) as Saldo \\n                FROM nubank_monthly_summary \\n                WHERE account_type = 'credit_card' \\n                AND mes >= strftime(DATE '${__from:date:YYYY-MM-DD}', '%Y-%m')\\n                AND mes <= strftime(DATE '${__to:date:YYYY-MM-DD}', '%Y-%m')\\n                ORDER BY mes DESC\"}",
              "method": "POST"
            }
