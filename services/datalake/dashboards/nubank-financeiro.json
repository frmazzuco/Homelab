            "type": "json",
            "url": "http://localhost:8089/query",
            "url_options": {
              "data": "{\"query\": \"SELECT \\n                    description as Servi\\u00e7o,\\n                    CASE \\n                        WHEN description ILIKE '%spotify%' THEN '\\ud83c\\udfb5 M\\u00fasica'\\n                        WHEN description ILIKE '%netflix%' THEN '\\ud83c\\udfac Streaming'\\n                        WHEN description ILIKE '%disney%' OR description ILIKE '%walt disney%' THEN '\\ud83c\\udfac Streaming'\\n                        WHEN description ILIKE '%hbo%' OR description ILIKE '%helphbomax%' THEN '\\ud83c\\udfac Streaming'\\n                        WHEN description ILIKE '%youtube%' THEN '\\ud83c\\udfac Streaming'\\n                        WHEN description ILIKE '%openai%' OR description ILIKE '%chatgpt%' THEN '\\ud83e\\udd16 IA'\\n                        WHEN description ILIKE '%claude%' THEN '\\ud83e\\udd16 IA'\\n                        WHEN description ILIKE '%apple%' THEN '\\ud83d\\udcf1 Apple'\\n                        WHEN description ILIKE '%crossover%' THEN '\\ud83d\\udcbb Software'\\n                        ELSE '\\ud83d\\udce6 Outros'\\n                    END as Tipo,\\n                    COUNT(*) as Cobran\\u00e7as,\\n                    ROUND(AVG(ABS(amount)), 2) as \\\"Valor M\\u00e9dio\\\",\\n                    ROUND(SUM(ABS(amount)), 2) as \\\"Total Pago\\\"\\n                FROM nubank_transactions \\n                WHERE category IN ('Music streaming', 'Video streaming', 'Digital services')\\n                AND date >= '${__from:date:YYYY-MM-DD}' \\n                AND date <= '${__to:date:YYYY-MM-DD}'\\n                GROUP BY description, Tipo\\n                ORDER BY \\\"Total Pago\\\" DESC\"}",
              "method": "POST"
            }
          }
        ],
