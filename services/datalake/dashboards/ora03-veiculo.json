              "data": "{\"query\": \"\\n                        SELECT \\n                            CAST(timestamp AS VARCHAR)[:16] as \\\"Data/Hora\\\",\\n                            battery_soc as \\\"SOC %\\\",\\n                            battery_range_km as \\\"Autonomia km\\\",\\n                            odometer_km as \\\"Od\\u00f4metro km\\\",\\n                            tire_fl_pressure as \\\"DE\\\", tire_fr_pressure as \\\"DD\\\",\\n                            tire_rl_pressure as \\\"TE\\\", tire_rr_pressure as \\\"TD\\\",\\n                            CASE WHEN is_locked THEN '\\ud83d\\udd12' ELSE '\\ud83d\\udd13' END as Trava,\\n                            CASE WHEN is_charging THEN '\\u26a1' ELSE '\\u2014' END as Carga,\\n                            ROUND(latitude, 4) || ', ' || ROUND(longitude, 4) as Local\\n                        FROM ora03_snapshots\\n                        WHERE timestamp >= '${__from:date:YYYY-MM-DD}'\\n                        AND timestamp <= '${__to:date:YYYY-MM-DD}T23:59:59'\\n                        ORDER BY timestamp DESC\\n                    \"}",
