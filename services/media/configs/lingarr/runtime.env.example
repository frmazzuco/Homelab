# Lingarr runtime template (no secrets)
DB_CONNECTION=mysql
DB_HOST=lingarr-db
DB_PORT=3306
DB_DATABASE=lingarr
DB_USERNAME=lingarr
DB_PASSWORD=<set-via-local-secret>
SERVICE_TYPE=gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=<set-via-local-secret>

# Opcional para modo localai
LOCAL_AI_ENDPOINT=http://host.lima.internal:11434/api/generate
LOCAL_AI_MODEL=gemma3:12b
LOCAL_AI_API_KEY=ollama
AUTH_ENABLED=false
MAX_CONCURRENT_JOBS=2
