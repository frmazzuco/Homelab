# Pipeline de compressão pós-importação (Jellyfin/Radarr/Sonarr) - modo híbrido (macOS host)
MIN_SIZE_MB=1500
MIN_AGE_MIN=40
SCAN_LIMIT=1
DRY_RUN=0

# Encoder preferencial no Apple Silicon
ENCODER=hevc_videotoolbox
VT_Q=60

# Fallback software se hardware falhar
X265_CRF_FALLBACK=23
X265_PRESET_FALLBACK=medium

# Binários nativos
FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
FFPROBE_BIN=/opt/homebrew/bin/ffprobe
