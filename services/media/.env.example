# -----------------------------
# Host identity
# -----------------------------
TZ=America/Sao_Paulo
PUID=501
PGID=20

# -----------------------------
# Paths (ajuste para seu host)
# -----------------------------
ARR_CONFIG_ROOT=/Users/SEU_USUARIO/arr/config
ARR_CLOUDBEAVER_WORKSPACE=/Users/SEU_USUARIO/arr/cloudbeaver/workspace
MEDIA_ROOT=/Users/SEU_USUARIO/Media
MEDIA_DOWNLOADS_ROOT=/Users/SEU_USUARIO/Media/Entrada
JELLYFIN_CONFIG_DIR=/Users/SEU_USUARIO/jellyfin/config
JELLYFIN_CACHE_DIR=/Users/SEU_USUARIO/jellyfin/cache

# -----------------------------
# Images
# -----------------------------
APPRISE_IMAGE=lscr.io/linuxserver/apprise-api:latest
SEERR_ROUTER_IMAGE=homelab/seerr-router:local
JELLYSEERR_IMAGE=ghcr.io/seerr-team/seerr:latest
SABNZBD_IMAGE=lscr.io/linuxserver/sabnzbd:latest
SONARR_IMAGE=lscr.io/linuxserver/sonarr:latest
RADARR_IMAGE=lscr.io/linuxserver/radarr:latest
PROWLARR_IMAGE=lscr.io/linuxserver/prowlarr:latest
BAZARR_IMAGE=lscr.io/linuxserver/bazarr:latest
JELLYFIN_IMAGE=jellyfin/jellyfin:latest
LINGARR_DB_IMAGE=mariadb:11
LINGARR_IMAGE=lingarr/lingarr:latest
WHISPER_ASR_IMAGE=onerahmet/openai-whisper-asr-webservice:latest
UPTIME_KUMA_IMAGE=louislam/uptime-kuma:2
BESZEL_IMAGE=henrygd/beszel:latest
HOMEPAGE_IMAGE=ghcr.io/gethomepage/homepage:latest
CLOUDBEAVER_IMAGE=dbeaver/cloudbeaver:latest

# -----------------------------
# Exposure policy
# 127.0.0.1 = acessivel so no host
# 0.0.0.0   = acessivel pela rede
# -----------------------------
APPRISE_BIND_HOST=127.0.0.1
APPRISE_PORT=8000
JELLYSEERR_BIND_HOST=0.0.0.0
JELLYSEERR_PORT=5055
SABNZBD_BIND_HOST=0.0.0.0
SABNZBD_PORT=8086
SONARR_BIND_HOST=0.0.0.0
SONARR_PORT=8989
RADARR_BIND_HOST=0.0.0.0
RADARR_PORT=7878
PROWLARR_BIND_HOST=0.0.0.0
PROWLARR_PORT=9696
BAZARR_BIND_HOST=0.0.0.0
BAZARR_PORT=6767
JELLYFIN_BIND_HOST=127.0.0.1
JELLYFIN_PORT=8096
LINGARR_DB_BIND_HOST=0.0.0.0
LINGARR_DB_PORT=3307
LINGARR_BIND_HOST=0.0.0.0
LINGARR_PORT=9876
WHISPER_ASR_BIND_HOST=0.0.0.0
WHISPER_ASR_PORT=9000
UPTIME_KUMA_BIND_HOST=127.0.0.1
UPTIME_KUMA_PORT=3001
BESZEL_BIND_HOST=127.0.0.1
BESZEL_PORT=8093
HOMEPAGE_BIND_HOST=127.0.0.1
HOMEPAGE_PORT=3004
CLOUDBEAVER_BIND_HOST=127.0.0.1
CLOUDBEAVER_PORT=8978

# -----------------------------
# Apprise / notificacoes
# -----------------------------
APPRISE_STATELESS_URLS=tgram://<BOT_TOKEN>/<CHAT_ID>/
APPRISE_WORKER_COUNT=1

# -----------------------------
# Seerr Router (FastAPI)
# -----------------------------
SEERR_ROUTER_APPRISE_URL=http://apprise-api:8000/notify/
SEERR_ROUTER_SHARED_TOKEN=trocar_este_token
SEERR_ROUTER_DEFAULT_URLS=
SEERR_ROUTER_USER_DESTINATION_MAP={"franciscomazzuco":"tgram://<BOT_TOKEN>/<CHAT_ID_FRANCISCO>/","convidado":"tgram://<BOT_TOKEN>/<CHAT_ID_CONVIDADO>/"}
SEERR_ROUTER_HTTP_TIMEOUT_SECONDS=10
SEERR_ROUTER_LOG_LEVEL=info

# -----------------------------
# Jellyseerr
# -----------------------------
JELLYSEERR_LOG_LEVEL=info

# -----------------------------
# Lingarr
# -----------------------------
LINGARR_DB_NAME=lingarr
LINGARR_DB_USER=lingarr
LINGARR_DB_PASSWORD=trocar_esta_senha
LINGARR_DB_ROOT_PASSWORD=trocar_esta_senha
LINGARR_AUTH_ENABLED=false
LINGARR_SERVICE_TYPE=gemini
LINGARR_GEMINI_MODEL=gemini-2.5-flash
LINGARR_GEMINI_API_KEY=<GEMINI_API_KEY>
LINGARR_LOCAL_AI_ENDPOINT=http://host.lima.internal:11434/api/generate
LINGARR_LOCAL_AI_MODEL=gemma3:12b
LINGARR_LOCAL_AI_API_KEY=ollama
LINGARR_MAX_CONCURRENT_JOBS=2

# -----------------------------
# Whisper ASR
# -----------------------------
WHISPER_ASR_MODEL=small
WHISPER_ASR_ENGINE=faster_whisper

# -----------------------------
# Monitoring UI vars
# -----------------------------
BESZEL_APP_URL=http://mac-mini-de-francisco.tailf1e5f9.ts.net:8093
HOMEPAGE_ALLOWED_HOSTS=mac-mini-de-francisco.tailf1e5f9.ts.net:8094,mac-mini-de-francisco:8094,localhost:3004,127.0.0.1:3004
CLOUDBEAVER_UID=8978
CLOUDBEAVER_GID=8978
