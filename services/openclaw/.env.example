# Paths
OPENCLAW_CONFIG_DIR=/home/opc/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/opc/.openclaw/workspace

# Ports
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

# Image
OPENCLAW_IMAGE=openclaw:local

# SSH mounts (opcional)
OPENCLAW_SSH_KEY=/home/opc/.ssh/id_ed25519_github
OPENCLAW_SSH_CONFIG=/home/opc/.ssh/config
OPENCLAW_SSH_KNOWN_HOSTS=/home/opc/.ssh/known_hosts_github

# OpenClaw auth
OPENCLAW_GATEWAY_TOKEN=<OPENCLAW_GATEWAY_TOKEN>
CLAUDE_AI_SESSION_KEY=<CLAUDE_AI_SESSION_KEY>
CLAUDE_WEB_SESSION_KEY=<CLAUDE_WEB_SESSION_KEY>
CLAUDE_WEB_COOKIE=<CLAUDE_WEB_COOKIE>

# Pluggy (opcional, conforme integracao)
PLUGGY_CLIENT_ID=<PLUGGY_CLIENT_ID>
PLUGGY_CLIENT_SECRET=<PLUGGY_CLIENT_SECRET>
PLUGGY_API_KEY=<PLUGGY_API_KEY>
PLUGGY_BASE_URL=<PLUGGY_BASE_URL>
PLUGGY_API_KEY_TTL_SECONDS=3600
PLUGGY_CACHE_DIR=/home/node/.openclaw/cache
